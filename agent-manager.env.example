# Copy this file to agent-manager.env (git-ignored) and fill in your own values.
# launch.bat reads this file and sets each KEY=VALUE as an environment variable before
# starting the pipeline -- see README.md's "Configuration" section for the full reference.

# Required -- absolute path to the repo this pipeline operates on.
AGENT_MANAGER_REPO_ROOT=C:\path\to\your\repo

# Where queue/, instances/, and your own local task-source/applier scripts live.
# Defaults to AGENT_MANAGER_REPO_ROOT if unset -- uncomment to put pipeline state
# somewhere else (e.g. a subfolder, matching a consumer project's own backend/agent-pipeline/).
#AGENT_MANAGER_PIPELINE_DIR=C:\path\to\your\repo\agent-pipeline

# Path to a script the CLI entry points require() once, for its side effect of calling
# registerTaskSource/updateTaskSource for your own project-specific sources. Omit if you
# only want this package's 6 built-in sources with no project-specific additions.
#AGENT_MANAGER_REGISTER_PATH=C:\path\to\your\repo\agent-pipeline\my-sources.js

# A personal-notes vault, if you use the 'secondbrain' built-in source. Omit otherwise.
#SECOND_BRAIN_DIR=C:\path\to\your\vault

# The domain name stamped on trouble_log/arch_review/arch_discovery/unused_export tasks --
# must match a real key in your AGENT_MANAGER_DOMAINS_PATH file. Defaults to 'default'.
#AGENT_MANAGER_DEFAULT_DOMAIN=default

# e.g. https://github.com/you/repo/compare/main... -- appended with the pushed branch
# name in log output. Omit if you don't want a compare-URL link generated.
#AGENT_MANAGER_COMPARE_URL_BASE=https://github.com/you/repo/compare/main...

# Ollama connection -- defaults shown, uncomment to override.
#OLLAMA_URL=http://localhost:11434
#ORNITH_MODEL=ornith:9b

# Dashboard port -- defaults to 7420.
#AGENT_MANAGER_DASHBOARD_PORT=7420
